{
  "name": "lazy-project-launcher",
  "version": "1.1.0",
  "author": "longdh",
  "description": "A simple and efficient project launcher built with Electron and Vue.js for managing multiple development projects.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on tcp:12511 && electron . --disable-gpu --disable-software-rasterizer\" --kill-others",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "vite": "^5.0.0",
    "vue": "^3.3.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-gyp": "^12.3.0",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.lazyprojectlauncher.app",
    "productName": "Lazy Project Launcher",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "files": [
      "electron/**/*",
      "dist/**/*",
      "src/locale/**/*",
      "main.js",
      "icon.png",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
